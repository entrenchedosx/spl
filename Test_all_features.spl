// -----------------------------------------------------------------------------
// 52. str(), int(), float() conversion
// -----------------------------------------------------------------------------
try {
    let s = str(42)
    let i = int(3.7)
    let f = float(10)
    if (s == "42" && i == 3 && f >= 9.99 && f <= 10.01) {
        ok("str, int, float")
    } else {
        fail("str/int/float", str("s=", s, " i=", i, " f=", f))
    }
} catch (e) {
    fail("str/int/float", e)
}

// -----------------------------------------------------------------------------
// 53. freeze (returns copy)
// -----------------------------------------------------------------------------
try {
    let a = array(1, 2)
    let b = freeze(a)
    if (len(b) == 2 && b[0] == 1) {
        ok("freeze")
    } else {
        fail("freeze", str("len=", len(b)))
    }
} catch (e) {
    fail("freeze", e)
}

// -----------------------------------------------------------------------------
// SUMMARY
// -----------------------------------------------------------------------------
print("")
print("=============================================================================")
print(str("SUMMARY: ", passed, " passed, ", failed, " failed"))
print("=============================================================================")
if (failed > 0) {
    print("Failed sections:")
    for i in range(0, len(errors)) {
        print(str("  - ", errors[i]))
    }
}
print("")
if (failed == 0) {
    print("All tests passed.")
} else {
    print(str("Total failures: ", failed))
}
print("")
