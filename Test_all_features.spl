    let obj = { "a": { "b": 42 } }
    let val = obj?.a?.b
    if (val == 42) {
        ok("Optional chaining obj?.a?.b")
    } else {
        fail("Optional chaining obj", str("val=", val))
    }
} catch (e) {
    fail("Optional chaining obj", e)
